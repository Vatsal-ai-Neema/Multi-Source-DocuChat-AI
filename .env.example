# DocuChat AI — Environment Variables (Example)
# Copy: cp .env.example .env
# Never commit .env

# LLM provider: `gemini` or `openrouter`
LLM_PROVIDER=gemini

# Gemini (Google)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (optional)
# Get key from OpenRouter dashboard.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Example: openrouter/auto or any model you have access to on OpenRouter
OPENROUTER_MODEL=openrouter/auto
# Optional headers recommended by OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Multi-Source DocuChat AI

# App Settings (Optional)
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# MAX_RETRIEVED_CHUNKS=4
